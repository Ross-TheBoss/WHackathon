# Copy this file to .env on your EC2 host and set secure values.

MYSQL_ROOT_PASSWORD=change-this-root-password
MYSQL_DATABASE=whackathon
MYSQL_USER=appuser
MYSQL_PASSWORD=change-this-app-password
SECRET_KEY=change-this-to-a-long-random-secret

# Frontend build-time API URL (public backend URL)
REACT_APP_API_URL=http://YOUR_EC2_PUBLIC_DNS:8000
